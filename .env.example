# Copy to .env and adjust as needed. Nothing here is a real secret.

# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://nutrition:nutrition@localhost:55432/nutrition_tracker"
# Direct (non-pooled) connection for migrations. Locally: same as DATABASE_URL.
DIRECT_URL="postgresql://nutrition:nutrition@localhost:55432/nutrition_tracker"

# --- Auth.js --------------------------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-value"
AUTH_URL="http://localhost:3000"

# Magic-link email provider. In development, emails are logged to the
# console instead of sent (see src/server/email.ts) unless SMTP_HOST is set.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="NutriTrail <no-reply@example.com>"

# --- AI meal analysis -------------------------------------------------------
# "mock" (default) needs no key and returns deterministic sample data.
# "openai" enables the real vision-capable adapter.
AI_PROVIDER="mock"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"

# --- Object storage (meal images) ------------------------------------------
# "local" (default) writes to ./public/uploads for development.
# "vercel-blob" uses Vercel Blob (BLOB_READ_WRITE_TOKEN is injected by the
# linked Blob store on Vercel; required when deploying there).
# "s3" uses the S3-compatible adapter below.
STORAGE_PROVIDER="local"
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION=""
STORAGE_S3_ACCESS_KEY_ID=""
STORAGE_S3_SECRET_ACCESS_KEY=""
STORAGE_S3_ENDPOINT=""

# --- Barcode / external food lookup ----------------------------------------
FOOD_PROVIDER="mock"

# --- Misc -------------------------------------------------------------------
NODE_ENV="development"
